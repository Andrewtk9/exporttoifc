{
  "name": "paula",
  "version": "1.0.0",
  "description": "Conversor de arquivos 3D (FBX, OBJ, glTF, DAE) para IFC",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder"
  },
  "keywords": [
    "ifc",
    "converter",
    "bim",
    "3d"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "assimpjs": "^0.0.10",
    "fbx-parser": "^2.1.3",
    "koffi": "^2.15.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.1",
    "web-ifc": "^0.0.75"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.paula.converter",
    "productName": "Paula",
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "node_modules/web-ifc/",
        "to": "web-ifc",
        "filter": [
          "*.wasm"
        ]
      }
    ]
  }
}
